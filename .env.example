# Copy to ".env" and fill in your Grafana Cloud OTLP details, then run:
#   ./scripts/run-with-tracing.sh
#
# In Grafana Cloud: Connections -> Add new connection -> OpenTelemetry (OTLP) -> "Java".
# It tells you to download grafana-opentelemetry-java.jar and shows these exact values.

OTEL_SERVICE_NAME=bottleneck-springboot

# Your OTLP endpoint (base URL ending in /otlp). The zone differs per account, e.g.
# prod-us-east-0, prod-eu-west-2, prod-ap-southeast-1, ...
OTEL_EXPORTER_OTLP_ENDPOINT=https://otlp-gateway-prod-ap-southeast-1.grafana.net/otlp

# Grafana Cloud's OTLP gateway speaks HTTP/protobuf.
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf

# Free-form labels that show up on every span/metric in Grafana.
OTEL_RESOURCE_ATTRIBUTES=service.namespace=mortillan,deployment.environment=local

# Auth header = base64 of "INSTANCE_ID:API_TOKEN". Generate it:
#   printf '%s' '123456:glc_xxxxxxxxxxxxxxxxxxxx' | base64
# Then paste the result after "Basic " (keep the quotes):
OTEL_EXPORTER_OTLP_HEADERS="Authorization=Basic PASTE_BASE64_HERE"
